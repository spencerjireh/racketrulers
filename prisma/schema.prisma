generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models (Auth.js) ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?

  accounts     Account[]
  sessions     Session[]
  events       Event[]
  coachProfile CoachProfile?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── Tournament Models ───────────────────────────────────────────────────────

enum EventStatus {
  PUBLISHED
  COMPLETED

  @@map("event_status")
}

model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  bannerUrl   String?     @map("banner_url")
  status      EventStatus @default(PUBLISHED)
  timezone    String      @default("America/Toronto")
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")

  pointsConfig  Json @default("{\"win\": 2, \"draw\": 1, \"loss\": 0}") @map("points_config")
  scoringConfig Json @default("{\"pointsPerSet\": 21, \"totalSets\": 3, \"deuceEnabled\": true, \"maxPoints\": 30}") @map("scoring_config")

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id])

  deletedAt DateTime? @map("deleted_at")

  categories Category[]
  teams      Team[]
  locations  Location[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([deletedAt])
  @@map("events")
}

model Category {
  id   String @id @default(cuid())
  name String
  order Int   @default(0)

  tiebreakerConfig Json @default("{\"order\": [\"win_loss\", \"head_to_head\", \"point_differential\", \"points_scored\"]}") @map("tiebreaker_config")
  drawsAllowed     Boolean @default(false) @map("draws_allowed")

  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  rounds        Round[]
  categoryTeams CategoryTeam[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum RoundType {
  ROUND_ROBIN
  SWISS
  SINGLE_ELIM
  DOUBLE_ELIM
  CUSTOM

  @@map("round_type")
}

model Round {
  id    String    @id @default(cuid())
  name  String
  type  RoundType
  order Int       @default(0)

  advancementRules Json? @map("advancement_rules")
  config           Json? // e.g. { consolation_match: true, reset_match: true }
  drawsAllowed     Boolean @default(false) @map("draws_allowed")

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  pools Pool[]
  games Game[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rounds")
}

model Pool {
  id   String @id @default(cuid())
  name String

  roundId String @map("round_id")
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  poolTeams PoolTeam[]
  games     Game[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pools")
}

model PoolTeam {
  id   String @id @default(cuid())
  seed Int    @default(0)

  poolId String @map("pool_id")
  pool   Pool   @relation(fields: [poolId], references: [id], onDelete: Cascade)

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([poolId, teamId])
  @@map("pool_teams")
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FORFEIT
  CANCELLED

  @@map("game_status")
}

enum MatchType {
  SINGLES
  DOUBLES

  @@map("match_type")
}

model Game {
  id             String     @id @default(cuid())
  status         GameStatus @default(SCHEDULED)
  matchType      MatchType  @default(SINGLES) @map("match_type")
  roundPosition  Int?       @map("round_position")
  scheduledAt    DateTime?  @map("scheduled_at")
  durationMinutes Int       @default(60) @map("duration_minutes")

  scoreTeam1 Int? @map("score_team1")
  scoreTeam2 Int? @map("score_team2")
  setScores  Json? @map("set_scores")

  team1Id String? @map("team1_id")
  team1   Team?   @relation("GameTeam1", fields: [team1Id], references: [id])

  team2Id String? @map("team2_id")
  team2   Team?   @relation("GameTeam2", fields: [team2Id], references: [id])

  roundId String @map("round_id")
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  poolId String? @map("pool_id")
  pool   Pool?   @relation(fields: [poolId], references: [id])

  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id])

  feederGame1Id String? @map("feeder_game_1_id")
  feederGame1   Game?   @relation("FeederGame1", fields: [feederGame1Id], references: [id])
  fedByGame1    Game[]  @relation("FeederGame1")

  feederGame2Id String? @map("feeder_game_2_id")
  feederGame2   Game?   @relation("FeederGame2", fields: [feederGame2Id], references: [id])
  fedByGame2    Game[]  @relation("FeederGame2")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([roundId, status])
  @@map("games")
}

model Team {
  id           String  @id @default(cuid())
  name         String
  captainName  String? @map("captain_name")
  captainEmail String? @map("captain_email")
  roster       Json    @default("[]")

  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  categoryTeams CategoryTeam[]
  poolTeams     PoolTeam[]
  gamesAsTeam1  Game[]         @relation("GameTeam1")
  gamesAsTeam2  Game[]         @relation("GameTeam2")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model CategoryTeam {
  id   String @id @default(cuid())
  seed Int    @default(0)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([categoryId, teamId])
  @@map("category_teams")
}

model Location {
  id   String @id @default(cuid())
  name String

  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  games Game[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

// ─── Coach Scheduler Models ──────────────────────────────────────────────────

model CoachProfile {
  id                     String @id @default(cuid())
  displayName            String @map("display_name")
  slug                   String @unique
  sessionDurationMinutes Int    @default(60) @map("session_duration_minutes")
  timezone               String @default("America/Toronto")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  availability CoachAvailability[]
  bookings     Booking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("coach_profiles")
}

model CoachAvailability {
  id        String @id @default(cuid())
  dayOfWeek Int    @map("day_of_week") // 0-6, Monday=0
  startTime String @map("start_time") // e.g. "09:00"
  endTime   String @map("end_time")   // e.g. "12:00"

  coachProfileId String       @map("coach_profile_id")
  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("coach_availability")
}

enum BookingStatus {
  CONFIRMED
  CANCELLED

  @@map("booking_status")
}

model Booking {
  id          String        @id @default(cuid())
  date        DateTime      @db.Date
  startTime   String        @map("start_time")
  endTime     String        @map("end_time")
  bookerName  String        @map("booker_name")
  bookerEmail String        @map("booker_email")
  message     String?
  status      BookingStatus @default(CONFIRMED)

  coachProfileId String       @map("coach_profile_id")
  coachProfile   CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([coachProfileId, date])
  @@map("bookings")
}
