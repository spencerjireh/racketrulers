DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
AUTH_SECRET="change-me-generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Soketi (server-side)
SOKETI_APP_ID="your-app-id"
SOKETI_APP_KEY="your-app-key"
SOKETI_APP_SECRET="your-app-secret"
SOKETI_HOST="your-soketi-host.example.com"
SOKETI_PORT="443"
SOKETI_USE_TLS="true"

# Soketi (client-side)
NEXT_PUBLIC_SOKETI_KEY="your-app-key"
NEXT_PUBLIC_SOKETI_HOST="your-soketi-host.example.com"
NEXT_PUBLIC_SOKETI_PORT="443"

# Invite codes (comma-separated) for organizer signup
INVITE_CODES="RACK-2025-ALPHA,RACK-2025-BETA"
